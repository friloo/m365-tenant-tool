RewriteEngine On

# Block direct access to backend directories — install/ is accessible (needed for setup wizard)
RewriteRule ^(src|config|views|storage|vendor)(/|$) - [F,L]
RewriteRule ^composer\.(json|lock)$ - [F,L]

# Route all requests to index.php (except real files and install/)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# Security headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # HSTS (only sends over HTTPS — Apache will ignore if HTTP)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" "expr=%{HTTPS} == 'on'"

    # Content Security Policy
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' cdn.jsdelivr.net 'unsafe-inline'; style-src 'self' cdn.jsdelivr.net 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' cdn.jsdelivr.net data:; connect-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self';"

    # Permissions Policy
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
</IfModule>

# Cache static assets
<FilesMatch "\.(css|js|png|svg|ico|woff2)$">
    <IfModule mod_headers.c>
        Header set Cache-Control "public, max-age=86400"
    </IfModule>
</FilesMatch>

# php_value only works with mod_php — use php.ini or php-fpm pool config for session settings
<IfModule mod_php.c>
    php_value session.cookie_httponly On
    php_value session.use_strict_mode On
</IfModule>
