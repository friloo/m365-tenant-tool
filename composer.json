{
    "name": "friloo/m365-tenant-tool",
    "description": "Microsoft 365 Tenant Management Dashboard via Graph API",
    "type": "project",
    "require": {
        "php": "^8.1",
        "microsoft/microsoft-graph": "^2.0",
        "guzzlehttp/guzzle": "^7.0",
        "vlucas/phpdotenv": "^5.5",
        "monolog/monolog": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "src/i18n_functions.php"
        ]
    },
    "config": {
        "optimize-autoloader": true
    }
}
